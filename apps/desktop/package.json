{
  "name": "@nook/desktop",
  "version": "0.1.0",
  "description": "Nook — local-first, spatial workboard desktop app.",
  "author": {
    "name": "Jayesh Patel",
    "email": "jaypatel6963@gmail.com"
  },
  "homepage": "https://github.com/itsmejay80/nook",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "build:electron": "node scripts/build.mjs",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "install-app-deps": "electron-builder install-app-deps",
    "pack": "electron-builder --mac --dir",
    "dist": "electron-builder --mac --arm64 --x64",
    "release": "electron-builder --mac --arm64 --x64 --publish always",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.itsmejay.nook",
    "productName": "Nook",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "package.json",
      {
        "from": "../renderer/dist",
        "to": "renderer-dist",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "identity": null
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "publish": {
      "provider": "github",
      "owner": "itsmejay80",
      "repo": "nook",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@nook/contracts": "workspace:*",
    "@nook/db": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
