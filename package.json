{
  "name": "nook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "test": "turbo run test",
    "package:mac": "turbo run build --filter=@nook/renderer --filter=@nook/desktop && bun --filter @nook/desktop run dist",
    "release:mac": "turbo run build --filter=@nook/renderer --filter=@nook/desktop && bun --filter @nook/desktop run release"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.6",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/instrument-sans": "^5.2.8"
  }
}
